# Template for the committer-proxy Worker config.
#
# The real `wrangler.toml` is a GENERATED artifact (gitignored): `setup.sh`
# copies this file to `wrangler.toml` and fills in the per-deployment values from
# your git remote + the GitHub App it creates. It's only read locally by
# `wrangler deploy` and never served to the browser, so it isn't committed.
#
# To deploy by hand instead of via setup.sh: copy this to `wrangler.toml`, fill
# in the placeholders, then `wrangler secret put` the three secrets + deploy.

name = "tally-worker"
main = "worker.js"
compatibility_date = "2024-11-01"

[vars]
# Filled by setup.sh from your git remote.
REPO_OWNER = "YOUR_GITHUB_LOGIN_OR_ORG"
REPO_NAME = "YOUR_REPO"
REPO_BRANCH = "main"
# Filled by setup.sh when it creates the App (both public, not secret).
GITHUB_APP_ID = ""
GITHUB_CLIENT_ID = ""
# Where login redirects back to (Pages URL).
SITE_URL = "https://YOUR_GITHUB_LOGIN.github.io/YOUR_REPO"
# Comma-separated GitHub user logins allowed to save. Empty = any signed-in
# user. setup.sh defaults this to the operator running it (NOT the repo owner,
# which for an org-owned repo is the org name and never matches a user login).
ALLOWED_LOGINS = ""
# Browser origins allowed to call the Worker (CORS).
ALLOWED_ORIGINS = "https://YOUR_GITHUB_LOGIN.github.io,http://localhost:8000"

# Shared-operator mode (docs/PLAN-shared.md). Leave UNSET for a normal
# single-repo self-hosted deploy. Set to "true" only on the operator's one
# Worker: then each signed-in user commits to their OWN repo (owner === login),
# under data/<login>/, and ALLOWED_LOGINS should be empty (any user).
# MULTI_TENANT = "true"

# Secrets (set with `wrangler secret put <NAME>`, do NOT put here):
#   GITHUB_APP_PRIVATE_KEY   App private key, PKCS#8 PEM
#   GITHUB_CLIENT_SECRET     OAuth client secret of the App
#   SESSION_SECRET           random string for signing session JWTs
